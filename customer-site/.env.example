# ─── Customer site env (Next.js) ──────────────────────────────────────
# Copy to .env.local for development. NEXT_PUBLIC_* vars are inlined into
# the client bundle at build time; non-public vars are server-only.

# Site URL — used by sitemap, robots, OG image, JSON-LD canonical URLs.
NEXT_PUBLIC_SITE_URL=https://delegendsbarbershop.lt

# Backend API base.
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Brand basics
NEXT_PUBLIC_SHOP_NAME="De Legends Barbershop"
NEXT_PUBLIC_SHOP_SHORT="De Legends"
NEXT_PUBLIC_CONTACT_EMAIL=contact@delegendsbarbershop.lt
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/delegendsbarbershop

# Legal entity — populate after MB registration. Leave empty in dev.
NEXT_PUBLIC_REG_NUMBER=
NEXT_PUBLIC_VAT_NUMBER=

# Office 1 — Senamiestis (Old Town · Pilies g. 38)
NEXT_PUBLIC_OFFICE_1_ADDRESS="Pilies g. 38, Vilnius"
NEXT_PUBLIC_OFFICE_1_POSTAL=LT-01123
NEXT_PUBLIC_OFFICE_1_PHONE=+37066375648
NEXT_PUBLIC_OFFICE_1_LAT=54.6802
NEXT_PUBLIC_OFFICE_1_LNG=25.2884

# Office 2 — Naujamiestis (Gedimino pr. 45)
NEXT_PUBLIC_OFFICE_2_ADDRESS="Gedimino pr. 45, Vilnius"
NEXT_PUBLIC_OFFICE_2_POSTAL=LT-01103
NEXT_PUBLIC_OFFICE_2_PHONE=+37060000002
NEXT_PUBLIC_OFFICE_2_LAT=54.6892
NEXT_PUBLIC_OFFICE_2_LNG=25.2710

# Plausible analytics — leave empty to disable. Self-hosted? Set _SRC too.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# Sentry — leave empty to disable error reporting.
NEXT_PUBLIC_SENTRY_DSN=
