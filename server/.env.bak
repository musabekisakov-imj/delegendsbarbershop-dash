# Local dev — using the system Postgres (Homebrew postgresql@14) instead of Docker.
# To use Docker instead, switch this to: postgresql://barberpro:devpass@localhost:5432/barberpro
DATABASE_URL="postgresql://musabekisakov@localhost:5432/barberpro_dev?schema=public"

NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3002,https://sculpture-enhancements-please-barnes.trycloudflare.com,https://cup-numerical-poet-satisfaction.trycloudflare.com,https://boxing-solving-brooklyn-dense.trycloudflare.com

# Public booking site (no auth) — single tenant for now.
# Pulled from seed output: tenant id is the first one in the table.
PUBLIC_TENANT_ID=cmoq59mc50000l690gufwk0md

JWT_SECRET=local-dev-only-do-not-use-in-prod-ddee3f81a92741fb
JWT_EXPIRES_IN=7d

EMAIL_DRY_RUN=true
EMAIL_FROM=BarberPro Test <noreply@example.com>
EMAIL_REPLY_TO=
RESEND_API_KEY=
