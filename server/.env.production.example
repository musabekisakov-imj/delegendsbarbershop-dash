# ─── Production env template (Vercel) ─────────────────
# Set these in: Vercel project → Settings → Environment Variables
# DO NOT commit a real .env.production file — that's the platform's job.

# ─── Database ─────────────────────────────────────────
# Vercel Postgres / Neon / Supabase / Railway connection string.
# IMPORTANT: append `?pgbouncer=true&connection_limit=1` for serverless,
# OR use a pooled connection string from the provider's dashboard.
# Prisma needs DIRECT_URL too if you use a pooler — for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# ─── App ──────────────────────────────────────────────
NODE_ENV=production
# PORT is ignored on Vercel (serverless function). Leave unset.

# Comma-separated production origins. Update after each frontend deploys
# and Vercel assigns its URL. Include both the apex and any preview alias.
ALLOWED_ORIGINS=https://app.delegendsbarbershop.lt,https://delegendsbarbershop.lt,https://barber-dashboard.vercel.app,https://barber-customer.vercel.app

# ─── Public booking site ──────────────────────────────
# Tenant ID for the customer-facing booking flow. Get from Postgres:
#   psql $DATABASE_URL -c "SELECT id FROM tenants LIMIT 1;"
PUBLIC_TENANT_ID=

# ─── Auth ─────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="De Legends Barbershop <bookings@delegendsbarbershop.lt>"
EMAIL_REPLY_TO=contact@delegendsbarbershop.lt
# Set to false in production so booking confirmations actually send.
EMAIL_DRY_RUN=false

# ─── Observability (optional) ─────────────────────────
# Sentry — leave empty to disable.
SENTRY_DSN=
