# ─── Database ─────────────────────────────────────────
# Local dev: docker-compose.yml starts a Postgres on :5432
DATABASE_URL="postgresql://barberpro:devpass@localhost:5432/barberpro?schema=public"

# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# All origins allowed for CORS — comma-separated.
# Include both the staff dashboard and the customer booking site.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5176,http://localhost:3000,https://barber-dash-inky.vercel.app

# ─── Public booking site (no auth) ────────────────────
# The single tenant ID that powers the customer-facing booking widget.
# Run: SELECT id FROM tenants LIMIT 1; — or check Prisma Studio.
PUBLIC_TENANT_ID=

# ─── Auth ─────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="change-me-in-production-this-is-not-secure"
JWT_EXPIRES_IN=7d
# Argon2 password hashing — defaults are fine

# ─── Email (Resend) ───────────────────────────────────
# Sign up at https://resend.com (free 3,000 emails/month)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx_your_key_here
EMAIL_FROM="BarberPro <bookings@yourdomain.com>"
EMAIL_REPLY_TO=support@yourdomain.com

# Toggle email sending in dev (true = no actual emails, just console.log)
EMAIL_DRY_RUN=true
